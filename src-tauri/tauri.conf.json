{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "funny_whiteboard",
  "version": "0.1.0",
  "identifier": "com.paint-test.desktop",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "funny_whiteboard",
        "width": 800,
        "height": 600,
        "maximized": true,
        "resizable": true,
        "transparent": true,
        "decorations": false,
        "shadow": false,
        "backgroundColor": "#00000000"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
